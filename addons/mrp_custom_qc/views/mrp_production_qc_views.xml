<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="mrp_production_form_view_inherit_qc" model="ir.ui.view">
            <field name="name">mrp.production.form.inherit.qc</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="mrp.mrp_production_form_view" />
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Quality Control" name="quality_control">
                        <group>
                            <group>
                                <field name="qc_status" />
                                <field name="qc_inspector_id" />
                            </group>
                            <group>
                                <field name="qc_notes"
                                    placeholder="Tulis catatan hasil inspeksi di sini..." />
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>